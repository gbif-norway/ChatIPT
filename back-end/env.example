# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Settings
SQL_ENGINE=django.db.backends.postgresql
SQL_DATABASE=chatipt
SQL_USER=postgres
SQL_PASSWORD=password
SQL_HOST=db
SQL_PORT=5432

# ORCID OAuth2 Settings
# Set ORCID_ENV to "sandbox" or "production". Defaults to production.
ORCID_ENV=sandbox
ORCID_CLIENT_ID=your-orcid-client-id
ORCID_CLIENT_SECRET=your-orcid-client-secret

# Optional: Create superuser on startup
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=your-superuser-password

# Frontend URL (for redirects and CORS)
FRONTEND_URL=http://localhost:3000

# CORS Settings (for React frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# Discord notifications (optional)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
# Optional: set this to @mention the developer reliably from webhook messages
DISCORD_DEVELOPER_USER_ID=123456789012345678
# Optional fallback if DISCORD_DEVELOPER_USER_ID is not set
DISCORD_DEVELOPER_HANDLE=@_rkian

# PDF manuscript pipeline
ENABLE_PDF_PIPELINE=True
PDF_MAX_PAGES=40
PDF_TABLE_CONFIDENCE_THRESHOLD=0.7
PDF_EXTRACTION_MODEL=gpt-5.4
PDF_EXTRACTION_FAILURE_ALERT_THRESHOLD=3
OPENAI_RESPONSES_TIMEOUT_SECONDS=180
PDF_EXTRACTION_OPENAI_TIMEOUT_SECONDS=600
